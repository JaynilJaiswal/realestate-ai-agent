          "project": "realestate-agent-portfolio",
          "rawQuery": true,
          "rawSql": "SELECT\n  TIMESTAMP_TRUNC(timestamp, MINUTE) AS time,\n  \n  -- Isolate LLM latency\n  AVG(CASE WHEN target_name = 'llama-3.3-70b-versatile' THEN latency_ms END) AS llm_latency,\n  \n  -- Isolate Database latency\n  AVG(CASE WHEN target_name = 'search_real_estate' THEN latency_ms END) AS db_search_latency,\n  \n  -- Isolate Web Scraper latency\n  AVG(CASE WHEN target_name = 'search_live_market_data' THEN latency_ms END) AS web_search_latency,\n  \n  -- Isolate Math Tool latency\n  AVG(CASE WHEN target_name = 'calculate_math_expression' THEN latency_ms END) AS math_latency\n\nFROM llmops_telemetry.agent_metrics\nWHERE $__timeFilter(timestamp)\nGROUP BY time\nORDER BY time",
